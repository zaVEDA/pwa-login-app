{
  "tests": [
    {
      "name": "GET следующий номер",
      "method": "GET",
      "path": "/?next_number=1",
      "headers": { "X-Phone": "+79001234567" },
      "expectedStatus": 200
    },
    {
      "name": "POST сохранить счёт",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": {
        "action": "save",
        "invoice_number": "2026-0001",
        "invoice_date": "2026-06-27",
        "client_type": "ip",
        "client_name": "ИП Иванов Иван Иванович",
        "client_inn": "123456789012",
        "items": [{ "name": "Консультация", "qty": "1", "price": "3000" }],
        "due_date": "2026-07-10",
        "comment": "Тестовый счёт"
      },
      "expectedStatus": 200
    },
    {
      "name": "GET список счетов",
      "method": "GET",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "expectedStatus": 200
    },
    {
      "name": "PDF генерация с кириллицей",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": {
        "action": "pdf",
        "invoice_date": "2026-06-27",
        "client_type": "ip",
        "client_name": "ИП Иванов Иван Иванович",
        "client_inn": "123456789012",
        "items": [{ "name": "Консультация психолога", "qty": "2", "price": "3000" }],
        "due_date": "2026-07-10",
        "comment": "Спасибо за обращение"
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Создать акт на основании счёта",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": {
        "action": "document",
        "doc_type": "act",
        "invoice_number": "2026-0001",
        "invoice_date": "2026-06-27",
        "client_name": "ИП Иванов Иван Иванович",
        "client_inn": "123456789012",
        "items": [{ "name": "Консультация психолога", "qty": "2", "price": "3000" }]
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Создать накладную на основании счёта",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": {
        "action": "document",
        "doc_type": "invoice_note",
        "invoice_number": "2026-0001",
        "invoice_date": "2026-06-27",
        "client_name": "ООО Ромашка",
        "client_inn": "1234567890",
        "items": [{ "name": "Товар", "qty": "5", "price": "100" }]
      },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Список документов реализации",
      "method": "GET",
      "path": "/?documents=1",
      "headers": { "X-Phone": "+79001234567" },
      "expectedStatus": 200
    },
    {
      "name": "Невалидный статус документа — 400",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": { "action": "set_document_status", "id": 999999, "status": "wrong" },
      "expectedStatus": 400
    },
    {
      "name": "Невалидный статус — 400",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": { "action": "set_status", "id": 999999, "status": "wrong" },
      "expectedStatus": 400
    },
    {
      "name": "Смена статуса несуществующего — 404",
      "method": "POST",
      "path": "/",
      "headers": { "X-Phone": "+79001234567" },
      "body": { "action": "set_status", "id": 999999, "status": "paid" },
      "expectedStatus": 404
    }
  ]
}