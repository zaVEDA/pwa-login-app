{
  "tests": [
    {
      "name": "CORS OPTIONS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Список без пароля запрещён",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401
    },
    {
      "name": "Проверка неверного пароля",
      "method": "POST",
      "path": "/",
      "body": {"action": "check_password", "password": "wrong-pass-xxx"},
      "expectedStatus": 401
    },
    {
      "name": "Загрузка без пароля запрещена",
      "method": "POST",
      "path": "/",
      "body": {"action": "upload", "name": "test.txt", "data": "eA=="},
      "expectedStatus": 401
    }
  ]
}
