{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Запрос SMS-кода для входа",
      "method": "POST",
      "path": "/",
      "headers": { "X-Device-Id": "test-device-1" },
      "body": { "action": "request_code", "purpose": "login", "channel": "sms", "phone": "+79991112233" },
      "expectedStatus": 200,
      "expectedBody": { "ok": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Проверка устройства",
      "method": "POST",
      "path": "/",
      "headers": { "X-Device-Id": "test-device-1" },
      "body": { "action": "check_device", "phone": "+79991112233" },
      "expectedStatus": 200
    },
    {
      "name": "Неверный код",
      "method": "POST",
      "path": "/",
      "headers": { "X-Device-Id": "test-device-1" },
      "body": { "action": "verify_code", "purpose": "login", "channel": "sms", "phone": "+79991112233", "code": "0000" },
      "expectedStatus": 400
    },
    {
      "name": "Вход по неверному паролю",
      "method": "POST",
      "path": "/",
      "body": { "action": "login_password", "login": "nouser", "password": "wrong" },
      "expectedStatus": 404
    },
    {
      "name": "Заявка на семейный тариф без сессии",
      "method": "POST",
      "path": "/",
      "body": { "action": "request_family_plan", "code_word": "тест" },
      "expectedStatus": 401
    },
    {
      "name": "Заявка на семейный тариф без кодового слова",
      "method": "POST",
      "path": "/",
      "body": { "action": "request_family_plan", "code_word": "" },
      "expectedStatus": 400
    },
    {
      "name": "Список заявок без прав администратора",
      "method": "POST",
      "path": "/",
      "body": { "action": "admin_list_family_requests" },
      "expectedStatus": 403
    },
    {
      "name": "Решение по заявке без прав администратора",
      "method": "POST",
      "path": "/",
      "body": { "action": "admin_decide_family_request", "request_id": 1, "decision": "approved" },
      "expectedStatus": 403
    },
    {
      "name": "Получить кодовое слово без прав администратора",
      "method": "POST",
      "path": "/",
      "body": { "action": "admin_get_family_code" },
      "expectedStatus": 403
    },
    {
      "name": "Назначить кодовое слово без прав администратора",
      "method": "POST",
      "path": "/",
      "body": { "action": "admin_set_family_code", "code_word": "Семья2026", "expires_at": "2026-12-31" },
      "expectedStatus": 403
    },
    {
      "name": "Назначить пароль пользователю без прав администратора",
      "method": "POST",
      "path": "/",
      "body": { "action": "admin_set_user_password", "login": "test", "password": "test123" },
      "expectedStatus": 403
    }
  ]
}